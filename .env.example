# Career Course Compass — Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# YouTube Data API Key
YOUTUBE_API_KEY=your_youtube_api_key

# MySQL Database (required for Vercel, optional for local dev)
# Local dev uses SQLite by default. Uncomment below for MySQL.
# MYSQL_URL=mysql://user:password@host:port/database

# Session secret (random 64-char hex string)
SESSION_SECRET=generate_a_random_64_char_hex_string_here

# Server port (local dev only)
PORT=3000
